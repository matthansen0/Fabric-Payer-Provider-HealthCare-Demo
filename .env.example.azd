# Copy to .env and adjust. Used by azd and postprovision bootstrap.

# Azure resource names (must be globally unique where required)
HUB_NAME="hls-healthcaredemo"
SEARCH_SERVICE_NAME="healthcarefoundryais"
FABRIC_CAPACITY_NAME="healthcarefabriccap"

# Optional overrides
PROJECT_NAME="HealthcareDemo-HLS"
LOCATION="swedencentral"
FABRIC_WORKSPACE_NAME="HealthcareDemo-WS"
FABRIC_LAUNCHER_NOTEBOOK_NAME="Healthcare_Launcher"
FABRIC_CAPACITY_SKU="F64"

# Turbo mode (set by scripts/azd/run_all.sh --turbodeploy)
TURBO_DEPLOY="false"
TURBO_SETUP_SKU="F256"
TURBO_SCALE_DOWN_SKU="F64"

# Notebook run polling controls
NOTEBOOK_RUN_POLL_SECONDS="30"
NOTEBOOK_RUN_MAX_MINUTES="240"
